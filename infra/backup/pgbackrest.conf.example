# Example pgBackRest config for a Citus cluster.
# This is a template: deploy pgBackRest sidecars/agents with proper SSH/TLS, object storage, encryption, and retention.

[global]
repo1-type=s3
repo1-s3-bucket=CHANGE_ME
repo1-s3-endpoint=CHANGE_ME
repo1-s3-region=CHANGE_ME
repo1-path=/pgbackrest/orders-citus
repo1-retention-full=7
repo1-retention-diff=14
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=CHANGE_ME_FROM_SECRET_MANAGER
process-max=4
log-level-console=info
start-fast=y
archive-async=y

# Coordinator metadata is critical. Back it up and archive WAL.
[citus-coordinator]
pg1-host=citus_coordinator
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-user=backup_user

# Each Citus worker stores distributed shard data. Add one stanza per worker in real production,
# or generate this file from inventory/service discovery.
[citus-worker1]
pg1-host=citus_worker1
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-user=backup_user

[citus-worker2]
pg1-host=citus_worker2
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-user=backup_user
