# Copy to .env and change every secret before any real deployment.
APP_ENV=development
TZ=Europe/Zagreb

POSTGRES_DB=gr5
POSTGRES_USER=gr5
# Local demo: direct value is OK. Production: prefer POSTGRES_PASSWORD_FILE.
POSTGRES_PASSWORD=change-me-please-use-a-long-random-secret
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

# Dedicated DB roles. Production must not run the app as POSTGRES_USER.
APP_DB_USER=app_user
# APP_DB_PASSWORD_FILE=/run/secrets/app_db_password
MIGRATION_DB_USER=migration_user
# MIGRATION_DB_PASSWORD_FILE=/run/secrets/migration_db_password
READONLY_DB_USER=readonly_user
# READONLY_DB_PASSWORD_FILE=/run/secrets/readonly_db_password
MONITORING_DB_USER=monitoring_user
# MONITORING_DB_PASSWORD_FILE=/run/secrets/monitoring_db_password
BACKUP_DB_USER=backup_user
# BACKUP_DB_PASSWORD_FILE=/run/secrets/backup_db_password

# Citus image. Use a pinned version in production, not latest/nightly.
CITUS_IMAGE=citusdata/citus:14-pg16
CITUS_WORKER_COUNT=2
CITUS_SHARD_COUNT=32

# Auth modes: disabled | api_key | jwt | api_key_or_jwt
AUTH_MODE=api_key_or_jwt
# API keys are split by privilege. Production should prefer *_FILE or external secret manager.
APP_API_KEY_READ=change-me-read-key
APP_API_KEY_WRITE=change-me-write-key
APP_API_KEY_ADMIN=change-me-admin-key
# APP_API_KEY_READ_FILE=/run/secrets/app_api_key_read
# APP_API_KEY_WRITE_FILE=/run/secrets/app_api_key_write
# APP_API_KEY_ADMIN_FILE=/run/secrets/app_api_key_admin
REQUIRE_API_KEY=false
JWT_SECRET=change-me-please-use-a-32-byte-minimum-jwt-secret
# JWT_SECRET_FILE=/run/secrets/jwt_secret
JWT_ISSUER=orders-demo
JWT_AUDIENCE=orders-api

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=5000
DB_IDLE_TRANSACTION_TIMEOUT_MS=10000

PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_RESERVE_POOL_SIZE=5

MAX_PAYLOAD_BYTES=8192
DEFAULT_LIST_LIMIT=50
MAX_LIST_LIMIT=500

# Optional gateway profile.
GATEWAY_HTTP_BIND=127.0.0.1:8080
GATEWAY_HTTPS_BIND=127.0.0.1:8443

# Direct coordinator connection for Alembic/Citus DDL. Do not run Citus DDL through PgBouncer transaction pooling.
MIGRATION_DB_HOST=citus_coordinator
MIGRATION_DB_PORT=5432

# Authorization and rate limits.
ENFORCE_TENANT_AUTH=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

# Metrics endpoint protection. In production set true and use METRICS_TOKEN_FILE.
METRICS_AUTH_ENABLED=false
# METRICS_TOKEN_FILE=/run/secrets/metrics_token

# Idempotency retention for POST /orders.
IDEMPOTENCY_RETENTION_DAYS=7

# TLS/mTLS. Local certs: ./scripts/init_tls_certs.sh. Production: use real CA/service-mesh/cloud CA.
POSTGRES_SSL=on
DB_SSLMODE=verify-full
DB_SSL_CA_FILE=/run/tls/ca.crt
DB_SSL_CERT_FILE=/run/tls/app_client.crt
DB_SSL_KEY_FILE=/run/tls/app_client.key
PGBOUNCER_CLIENT_TLS_SSLMODE=verify-ca
PGBOUNCER_SERVER_TLS_SSLMODE=verify-full

# Backup/restore.
BACKUP_ROOT=shared/backups
# RESTORE_CONFIRM=I_UNDERSTAND_THIS_REPLACES_DATA

# Runtime resource limits.
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPUS=1.0
APP_MEM_LIMIT=512m
APP_CPUS=0.50
PGBOUNCER_MEM_LIMIT=256m
PGBOUNCER_CPUS=0.25
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.25
NGINX_MEM_LIMIT=256m
NGINX_CPUS=0.25
PROMETHEUS_MEM_LIMIT=512m
PROMETHEUS_CPUS=0.50
POSTGRES_EXPORTER_MEM_LIMIT=128m
POSTGRES_EXPORTER_CPUS=0.25
